# Copy to .env and fill in values.
# The app runs fully with AI_PROVIDER=mock (no API keys needed).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# ── AI provider ───────────────────────────────────────────────────────────────
# "mock"      No keys needed. Hash-based embeddings + summariser LLM. Good for dev/demo.
# "openai"    Requires OPENAI_API_KEY. Uses text-embedding-3-small + gpt-4o-mini.
# "anthropic" Requires ANTHROPIC_API_KEY for chat (Claude Haiku). Embeddings fall back to mock
#             unless you also set OPENAI_API_KEY (Anthropic has no embeddings API).
# "gemini"    Requires GEMINI_API_KEY. Uses gemini-2.5-flash + gemini-embedding-001.
AI_PROVIDER=mock

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# Personal Access Token to clone PRIVATE repos. Public repos need nothing.
# Create at: https://github.com/settings/tokens  (scope: repo)
GITHUB_TOKEN=

# ── Persistence (RepoWiki DB + CodeGraph DB) ─────────────────────────────────
# PERSIST=true  → SQLite databases are written under DATA_DIR and the index reloads on restart.
# PERSIST=false → everything lives in in-memory SQLite (nothing survives a restart).
PERSIST=true
DATA_DIR=./data

# ── Embedding tuning ──────────────────────────────────────────────────────────
# Only used by the mock provider (real providers have a fixed dimension).
EMBEDDING_DIM=256

# ── Chunking tuning ───────────────────────────────────────────────────────────
# CHUNK_SIZE    approx characters per chunk (not tokens).
# CHUNK_OVERLAP trailing characters repeated at the start of the next chunk.
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
# TOP_K              chunks retrieved per question.
# HYBRID_RETRIEVAL   blend semantic search with keyword/symbol/path matching (recommended).
TOP_K=5
HYBRID_RETRIEVAL=true

# ── RepoWiki (per-file curated summaries) ────────────────────────────────────
# WIKI_ENABLED    generate a summary card per file during ingest.
# WIKI_LLM        use the LLM to write summaries (needs a real provider; costs tokens). Off = fast,
#                 deterministic summaries built from the file's structure.
# WIKI_MAX_FILES  cap how many files get summaries.
WIKI_ENABLED=true
WIKI_LLM=false
WIKI_MAX_FILES=300

# ── CodeGraph ─────────────────────────────────────────────────────────────────
# Max file nodes returned by GET /api/graph (keeps diagrams readable).
GRAPH_MAX_NODES=300
