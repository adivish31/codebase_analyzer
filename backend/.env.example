# Copy to .env and fill in values.
# The app runs fully with AI_PROVIDER=mock (no API keys needed).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# ── AI provider ───────────────────────────────────────────────────────────────
# "mock"      No keys needed. Hash-based embeddings + summariser LLM. Good for dev/demo.
# "openai"    Requires OPENAI_API_KEY. Uses text-embedding-3-small + gpt-4o-mini.
# "anthropic" Requires ANTHROPIC_API_KEY. Uses OpenAI embeddings + Claude Haiku for chat.
#             (Anthropic has no public embeddings API, so set AI_PROVIDER=openai for
#              embeddings and point LLM to anthropic, or just use "openai" for both.)
AI_PROVIDER=mock

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Embedding tuning ──────────────────────────────────────────────────────────
# Only used by the mock provider (real providers have a fixed dimension).
EMBEDDING_DIM=256

# ── Chunking tuning ───────────────────────────────────────────────────────────
# CHUNK_SIZE   approx characters per chunk (not tokens). Larger = more context per chunk,
#              fewer chunks total, but may exceed embedding model token limits.
# CHUNK_OVERLAP how many trailing characters of the previous chunk to repeat at the start
#              of the next. Higher overlap = fewer missed concepts at boundaries.
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
# How many chunks to retrieve and stuff into the LLM prompt per question.
# Higher = more context, but larger prompts cost more tokens.
TOP_K=5
